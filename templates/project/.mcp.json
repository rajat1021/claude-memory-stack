{
  "mcpServers": {
    "codebase-memory-mcp": {
      "command": "__CMS_CODEBASE_MEMORY_BIN__",
      "args": ["--project-dir", "."]
    },
    "memory-graph": {
      "command": "memorygraph",
      "args": ["--profile", "extended"],
      "env": {
        "MEMORY_BACKEND": "sqlite",
        "MEMORY_SQLITE_PATH": "./.claude/memory-graph.db"
      }
    },
    "postgres": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://claude:__CMS_DB_PASSWORD__@localhost:5433/claude_flow"
      ]
    }
  }
}
